# Backing 项目环境变量配置
# 复制此文件为 .env 并填入真实配置

# 数据库配置
# 开发环境可直接使用 sqlite；生产环境建议改为 MySQL
DATABASE_URL=sqlite:///./stock_backtest.db
# 如果使用 MySQL，可单独指定 bootstrap 库连接用于建库
# DB_BOOTSTRAP_URL=mysql+pymysql://user:password@localhost:3306

# 服务配置
HOST=0.0.0.0
PORT=8808
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
KLINE_PROVIDER=baostock
STOCK_LIST_PROVIDER=akshare

# DeepSeek / Tavily
DEEPSEEK_API_KEY=replace_me
TAVILY_API_KEY=replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Agent 配置
AGENT_ORCHESTRATOR_MODE=standard
AGENT_MAX_STEPS=6
AGENT_ORCHESTRATOR_TIMEOUT_S=600
AGENT_MEMORY_ENABLED=false
AGENT_RISK_OVERRIDE=true

# 代理配置（USE_PROXY=true 时必须填写下面两项）
USE_PROXY=false
# PROXY_HOST=
# PROXY_PORT=

# 策略优化保护阈值
MAX_OPTIMIZE_COMBINATIONS=200

# API 认证密钥（必填，用于保护所有 API 端点）
# 可以使用以下命令生成：python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_secret_api_key_here

# 自选股列表（仪表盘显示）- 用逗号分隔股票代码
WATCHLIST_STOCKS=sh.600000,sh.600519,sh.601318,sh.000001,sz.000001,sz.399001,sz.399006
